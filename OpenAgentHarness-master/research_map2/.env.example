# 复制为 .env.local 后按需修改（不要提交含密钥的 .env.local）

# 开发时 Vite 把 /oah 代理到该地址（默认 8787）。若报 ECONNREFUSED，请先启动 OAH，或改成实际端口：
# VITE_OAH_DEV_PROXY_TARGET=http://127.0.0.1:8787

# OAH HTTP API 前缀（开发时多为 Vite 代理路径）
# VITE_OAH_API_BASE=/oah/api/v1

# 可选：固定 workspace id（多 workspace 自动探测时可不填）
# VITE_OAH_WORKSPACE_ID=

# ---------- 通用研究助手（原 framing + discovery 合并为同一 OAH agent：general）----------
# 与 `.openharness/settings.yaml` 中 default_agent 及 `agents/general.md` 一致时，可省略下列项（代码默认使用 agent 名 general）。
#
# 显式指定通用通道的 OAH agent 名（推荐，语义最清晰）：
# VITE_OAH_AGENT_GENERAL=general
#
# 若历史项目只配置了「全局默认 agent」变量，仍可生效（优先级低于 VITE_OAH_AGENT_GENERAL）：
# VITE_OAH_AGENT_NAME=general
#
# 若后端 workspace 尚未注册 general，仅保留旧 agent 时，可二选一指向现有名字（优先级低于上面两项）：
# VITE_OAH_AGENT_DISCOVERY=discovery
# VITE_OAH_AGENT_FRAMING=framing

# 其它专项助手（与模板中 agents/*.md 文件名一致即可）
# VITE_OAH_AGENT_READING=reading
# VITE_OAH_AGENT_WRITING=writing
# VITE_OAH_AGENT_LITERATURE_REVIEW=literature_review

# 模板模式：按 sessionScope 隔离会话（默认 true）
# VITE_OAH_TEMPLATE_MODE=true

# 文献解析 API（未配置时等价于 {VITE_OAH_API_BASE}/documents/parse）
# VITE_OAH_DOC_PARSE_API=
# VITE_OAH_DOC_PARSE_DISABLED=false

# 浏览器侧多源检索（Crossref / OpenAlex 等）
# VITE_REAL_DISCOVERY_SEARCH=true
# VITE_SEMANTIC_SCHOLAR_API_KEY=
# VITE_GOOGLE_CSE_API_KEY=
# VITE_GOOGLE_CSE_CX=
